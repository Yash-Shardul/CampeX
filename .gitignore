# ─────────────────────────────────────────────
#  CampeX — Root .gitignore
# ─────────────────────────────────────────────

# Node dependencies (client & server)
node_modules/
**/node_modules/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db

# Build output
dist/
build/

# Testing
coverage/
.nyc_output/

# Optional caches
.npm
.eslintcache
.pnp
.pnp.js

# Upload folders (add a .gitkeep if you want the folder tracked)
server/uploads/*
!server/uploads/.gitkeep
